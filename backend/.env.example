# ─── AWS Configuration ───────────────────────────────────────
# On EC2/ECS with IAM roles these are NOT needed.
# Only set for local development:
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_PROFILE=neurocode-dev          # alternative to explicit keys
AWS_REGION=us-east-1

# ─── S3 ──────────────────────────────────────────────────────
S3_BUCKET=neurocode-ai-snippets

# ─── DynamoDB ────────────────────────────────────────────────
DYNAMODB_TABLE=neurocode-analyses

# ─── SQS ─────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/neurocode-jobs

# ─── Lambda ──────────────────────────────────────────────────
LAMBDA_FUNCTION_NAME=neurocode-process-job

# ─── CloudWatch ──────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=/neurocode-ai/backend

# ─── App Settings ────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000
